{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "jsx": "react-jsx",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "types": [
      "@tarojs/taro",
      "@tarojs/components"
    ]
  },
  "include": [
    "src",
    "config",
    "types"
  ]
}
